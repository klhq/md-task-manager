# Telegram Bot Configuration
# Get your bot token from BotFather on Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Secret token to verify webhook requests (recommended for security)
BOT_SECRET=
# Webhook URL for Telegram (used by set:webhook and clear:updates scripts)
WEBHOOK_URL=https://your-domain.vercel.app/api
# Telegram Bot Whitelist Chat IDs (comma-separated for multiple)
TELEGRAM_BOT_WHITELIST=123456789

# GitHub Token for accessing GitHub API
PROVIDER_API_KEY=github_pat_YOUR_TOKEN_HERE
# Path to the tasks file in the GitHub repository
# Format: https://github.com/owner/repo/blob/branch/path/to/file.md
FILE_PATH=https://github.com/your-username/your-repo/blob/main/task-table.md

# Google Calendar API Configuration (Optional)
# For Development: Use file path
GOOGLE_CALENDAR_CREDENTIALS_PATH=./google-api-credentials.json
# For Production: Use individual env vars
GOOGLE_CALENDAR_PRIVATE_KEY=
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PROJECT_ID=
# Calendar ID (Required for both dev and prod)
GOOGLE_CALENDAR_ID=your-email@gmail.com

# AI Provider: gemini | openai (also works with Groq, Together, Ollama) | anthropic
AI_PROVIDER=gemini
# Model name (works across providers, defaults to gemini-2.5-flash)
AI_MODEL=gemini-2.5-flash

# Gemini API Key (required if AI_PROVIDER=gemini)
GOOGLE_GENERATIVE_AI_KEY=your_gemini_api_key_here

# OpenAI-compatible API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=
# Optional: set base URL for non-OpenAI providers (Groq, Together, Ollama, etc.)
OPENAI_BASE_URL=

# Anthropic API Key (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Server Configuration
PORT=3000
NODE_ENV=development

# Cron Secret (Test values)
CRON_SECRET=your_random_cron_secret_here

# GitHub Webhook Secret (for receiving push notifications)
# Generate a random string and use the same value when configuring the webhook in GitHub
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret_here