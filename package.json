{
  "name": "md-task-manager",
  "version": "1.0.0",
  "description": "Telegram bot that manages tasks in a Markdown file with AI parsing, Google Calendar sync, and GitHub storage",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prebuild": "bun src/scripts/generateChangelog.ts",
    "build": "tsc --noEmit",
    "start": "bun --env-file=.env src/app.ts",
    "predev": "bun src/scripts/generateChangelog.ts",
    "dev": "bun --watch --env-file=.env src/dev.ts",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix --max-warnings 0",
    "format": "prettier --write src/**/*.ts",
    "set:webhook": "bun --env-file=.env src/scripts/tg/setWebhook.ts",
    "get:webhook": "bun --env-file=.env src/scripts/tg/getWebhookInfo.ts",
    "clear:updates": "bun --env-file=.env src/scripts/tg/clearUpdate.ts"
  },
  "keywords": [
    "telegram-bot",
    "task-manager",
    "markdown",
    "google-calendar",
    "grammy"
  ],
  "author": "@lazyskyline7",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/lazyskyline7/md-task-manager"
  },
  "bugs": {
    "url": "https://github.com/lazyskyline7/md-task-manager/issues"
  },
  "homepage": "https://github.com/lazyskyline7/md-task-manager#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "@googleapis/calendar": "^14.2.0",
    "@grammyjs/auto-chat-action": "^0.1.1",
    "@hono/node-server": "^1.19.11",
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.141",
    "date-fns-tz": "^3.2.0",
    "google-auth-library": "^10.5.0",
    "grammy": "^1.41.1",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.7",
    "bun-types": "latest",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.0.0",
    "typescript": "5.4.5",
    "typescript-eslint": "^8.0.0"
  }
}
